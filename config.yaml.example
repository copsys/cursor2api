# Cursor2API v2 configuration
# Copy to config.yaml and adjust as needed.
#
# Environment variables override everything here and take highest priority.

port: 3010                     # Server port
timeout: 120                   # Idle timeout in seconds
cursor_model: "anthropic/claude-sonnet-4.6"

# -------------------- Auth (recommended for public deployments) --------------------
# All POST routes require a token when configured.
# Send via Authorization: Bearer <token> or x-api-key: <token>
# ENV: AUTH_TOKEN=token1,token2
# auth_tokens:
#   - "sk-your-secret-token-1"
#   - "sk-your-secret-token-2"

# -------------------- Proxy --------------------
# Upstream proxy for all requests (http/https). PROXY env var also supported.
# proxy: "http://user:pass@127.0.0.1:7890"

# -------------------- Continuations --------------------
# How many automatic continuations to attempt when Cursor truncates output.
# 0 = disabled (let the client handle it). 1-3 = proxy will continue internally.
# ENV: MAX_AUTO_CONTINUE=0
max_auto_continue: 0

# -------------------- History limits --------------------
# Hard cap on message count (-1 for unlimited).
# ENV: MAX_HISTORY_MESSAGES=100
max_history_messages: -1

# Token-based cap (recommended). Uses js-tiktoken estimates; -1 for unlimited.
# Leave headroom for Cursor’s own system prompts and your desired output size.
# ENV: MAX_HISTORY_TOKENS=120000
max_history_tokens: 120000

# Inflate reported input_tokens to trigger client-side compression earlier.
# 1.35 ≈ 200k/150k (Cursor’s effective window). 1.0 disables inflation.
# ENV: CONTEXT_PRESSURE=1.35
# context_pressure: 1.35

# -------------------- Thinking override --------------------
# Follows client by default. Force on/off with:
# ENV: THINKING_ENABLED=true|false
thinking:
  enabled: false

# -------------------- Compression --------------------
compression:
  enabled: true               # ENV: COMPRESSION_ENABLED=true|false
  level: 2                    # 1=light, 2=medium, 3=aggressive (ENV: COMPRESSION_LEVEL)
  # keep_recent: 6            # Override defaults from level
  # early_msg_max_chars: 2000

# -------------------- Tools --------------------
tools:
  schema_mode: 'compact'      # compact | full | names_only
  description_max_length: 100
  # include_only:             # Whitelist tool names
  #   - "Read"
  # exclude:                  # Blacklist tool names
  #   - "SomeTool"
  passthrough: false          # ENV: TOOLS_PASSTHROUGH
  disabled: false             # ENV: TOOLS_DISABLED
  # adaptive_budget: true     # ENV: TOOLS_ADAPTIVE_BUDGET
  # smart_truncation: true    # ENV: TOOLS_SMART_TRUNCATION

# -------------------- Response sanitization --------------------
# Replace Cursor identity mentions with Claude, strip tool-availability claims, etc.
# ENV: SANITIZE_RESPONSE=true|false
# sanitize_response: true

# -------------------- Custom refusal detection --------------------
# Added after built-in patterns; supports hot reload.
# refusal_patterns:
#   - "I must decline"
#   - "我无法协助"

# -------------------- Fingerprint --------------------
fingerprint:
  user_agent: "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/140.0.0.0 Safari/537.36"

# -------------------- Vision (optional) --------------------
vision:
  enabled: true
  mode: 'ocr'                # 'ocr' (local CPU OCR) or 'api' (external vision API)
  # base_url: "https://openrouter.ai/api/v1/chat/completions"
  # api_key: "sk-or-..."
  # model: "meta-llama/llama-3.2-11b-vision-instruct:free"
  # proxy: "http://127.0.0.1:7890"   # Dedicated proxy for vision API

# -------------------- Logging --------------------
logging:
  # JSONL file persistence
  file_enabled: false        # ENV: LOG_FILE_ENABLED
  dir: "./logs"
  max_days: 7
  persist_mode: summary      # compact | full | summary

  # SQLite persistence (recommended for large logs)
  db_enabled: false          # ENV: LOG_DB_ENABLED
  db_path: "./logs/cursor2api.db"
